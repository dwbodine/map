{
  "name": "marie-anna-photography",
  "version": "3.0.0",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "start": "webpack serve --mode development",
    "format": "prettier --write \"src/**/*.js\"",
    "eslint-fix": "eslint --fix \"src/**/*.js\"",
    "build": "webpack --mode production",
    "s3-clean": "aws s3 rm s3://marieannaphotography.com --recursive --exclude '*' --include 'main*'",
    "deploy-html": "aws s3 sync dist/ s3://marieannaphotography.com --acl public-read",
    "deploy-content": "aws s3 sync public/ s3://marieannaphotography.com --acl public-read --exclude '*index.html'",
    "deploy": "yarn build && yarn s3-clean && yarn deploy-content && yarn deploy-html"
  },
  "dependencies": {
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "@mui/material": "^5.15.9",
    "axios": "^1.6.7",
    "prop-types": "^15.7.2",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-hook-form": "^7.50.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^5.2.0",
    "react-slideshow-image": "^3.7.5"
  },
  "devDependencies": {
    "@babel/core": "^7.13.10",
    "@babel/plugin-proposal-class-properties": "^7.13.0",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-runtime": "^7.13.10",
    "@babel/preset-env": "^7.13.10",
    "@babel/preset-react": "^7.12.13",
    "@hot-loader/react-dom": "^17.0.2",
    "assets-webpack-plugin": "^7.0.0",
    "babel-core": "^6.26.3",
    "babel-eslint": "^10.1.0",
    "babel-loader": "^8.2.2",
    "cleandir-webpack-plugin": "^0.1.4",
    "core-js": "^3.9.1",
    "css-loader": "^5.1.3",
    "eslint": "^7.22.0",
    "eslint-config-react": "^1.1.7",
    "eslint-loader": "^4.0.2",
    "eslint-plugin-react": "^7.23.0",
    "html-webpack-plugin": "^5.3.1",
    "prettier": "2.2.1",
    "raw-loader": "^4.0.2",
    "react-hot-loader": "^4.13.0",
    "regenerator-runtime": "^0.13.7",
    "style-loader": "^2.0.0",
    "webpack": "^5.26.2",
    "webpack-cli": "^4.5.0",
    "webpack-dev-server": "^3.11.2",
    "webpack-merge": "^5.7.3"
  }
}
